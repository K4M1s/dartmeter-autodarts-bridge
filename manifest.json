{
  "manifest_version": 3,
  "name": "DartMeter Bridge for autodarts",
  "version": "0.3.1",
  "description": "Forwards camera-detected throws from your play.autodarts.io session into DartMeter. Rides your existing autodarts login — no passwords, no tokens stored.",
  "homepage_url": "https://github.com/K4M1s/dartmeter-autodarts-bridge",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://play.autodarts.io/*",
    "https://dartmeter.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://play.autodarts.io/*"
      ],
      "js": [
        "src/shared.js",
        "src/content-autodarts.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://dartmeter.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "src/shared.js",
        "src/content-dartmeter.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/inject-autodarts.js"
      ],
      "matches": [
        "https://play.autodarts.io/*"
      ]
    }
  ]
}
